{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Flask-backed webview + opener + clipboard for job links",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1:*",
      "http://localhost:*"
    ]
  },
  "permissions": [
    "core:default",
    "opener:default",
    "clipboard-manager:allow-write-text"
  ]
}
