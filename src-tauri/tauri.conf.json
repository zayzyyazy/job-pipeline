{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Job Pipeline",
  "version": "0.1.0",
  "identifier": "com.zay.jobpipeline",
  "build": {
    "frontendDist": "../.static-placeholder"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Job Pipeline",
        "url": "http://127.0.0.1:5000",
        "width": 1280,
        "height": 850,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}